{
  "name": "@jiangzhx/tencent-ads-marketing-api-sdk",
  "version": "1.7.84-port.3",
  "description": "TypeScript SDK for Tencent Ads Marketing API.",
  "homepage": "https://github.com/jiangzhx/adcli/tree/main/packages/tencent-ads-marketing-api-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jiangzhx/adcli.git",
    "directory": "packages/tencent-ads-marketing-api-sdk"
  },
  "bugs": {
    "url": "https://github.com/jiangzhx/adcli/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js"
    },
    "./api/v3": {
      "types": "./dist/api/v3/index.d.ts",
      "import": "./dist/api/v3/index.js"
    },
    "./model": {
      "types": "./dist/model/index.d.ts",
      "import": "./dist/model/index.js"
    },
    "./model/v3": {
      "types": "./dist/model/v3/index.d.ts",
      "import": "./dist/model/v3/index.js"
    },
    "./config": {
      "types": "./dist/config/configuration.d.ts",
      "import": "./dist/config/configuration.js"
    },
    "./config/v3": {
      "types": "./dist/config/v3/configuration.d.ts",
      "import": "./dist/config/v3/configuration.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "bun scripts/build.ts",
    "prepack": "bun run build",
    "test": "bun test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "typescript": ">=5"
  },
  "devDependencies": {
    "@types/json-bigint": "^1.0.4",
    "@types/node": "^20",
    "typescript": "^5"
  },
  "dependencies": {
    "json-bigint": "^1.0.0"
  }
}
