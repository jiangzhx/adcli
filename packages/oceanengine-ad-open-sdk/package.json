{
  "name": "@jiangzhx/oceanengine-ad-open-sdk",
  "version": "1.1.87-port.6",
  "description": "TypeScript SDK for OceanEngine Ads Open Platform OpenAPI.",
  "homepage": "https://github.com/jiangzhx/adcli/tree/main/packages/oceanengine-ad-open-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jiangzhx/adcli.git",
    "directory": "packages/oceanengine-ad-open-sdk"
  },
  "bugs": {
    "url": "https://github.com/jiangzhx/adcli/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.js"
    },
    "./models": {
      "types": "./dist/models/index.d.ts",
      "import": "./dist/models/index.js"
    },
    "./config": {
      "types": "./dist/config/configuration.d.ts",
      "import": "./dist/config/configuration.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "bun scripts/build.ts",
    "prepack": "bun run build",
    "test": "bun test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "typescript": ">=5"
  },
  "devDependencies": {
    "@types/json-bigint": "^1.0.4",
    "@types/node": "^20",
    "typescript": "^5"
  },
  "dependencies": {
    "json-bigint": "^1.0.0"
  }
}
