{
  "name": "@jiangzhx/oceanengine-ad-open-sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for OceanEngine Ads Open Platform OpenAPI.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "src",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./apis": {
      "types": "./src/apis.ts",
      "import": "./src/apis.ts"
    },
    "./models": {
      "types": "./src/models.ts",
      "import": "./src/models.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "bun test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "typescript": ">=5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5"
  }
}
