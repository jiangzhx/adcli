{
  "name": "@jiangzhx/oceanengine-sdk",
  "version": "0.1.0",
  "description": "Node.js/TypeScript SDK port of oceanengine/ad_open_sdk_java.",
  "type": "module",
  "sideEffects": false,
  "files": [
    "src/index.ts",
    "src/runtime",
    "src/generated",
    "README.md",
    "PORTING.md"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./generated/apis": {
      "types": "./src/generated/apis.ts",
      "import": "./src/generated/apis.ts"
    },
    "./generated/models": {
      "types": "./src/generated/models.ts",
      "import": "./src/generated/models.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "generate": "bun run scripts/generate-from-java-sdk.ts",
    "test": "bun test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "typescript": ">=5"
  },
  "devDependencies": {
    "@types/node": "^20",
    "typescript": "^5"
  }
}
